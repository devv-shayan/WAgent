{
  "manifest_version": 3,
  "name": "WA Chat Backup (personal)",
  "version": "0.1.0",
  "description": "Export your own WhatsApp Web chats to JSON / HTML / media. For personal backup use.",
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["vendor/wppconnect-wa.js", "src/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ]
}
