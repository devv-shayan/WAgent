# --- Text agent model ---
# Default: Gemini (cloud). Requires GEMINI_API_KEY below.
GEMINI_API_KEY=your-gemini-api-key-here
AGENT_MODEL=gemini/gemini-2.5-flash

# Run the text agent FULLY LOCAL with Ollama (https://ollama.com):
#   ollama pull gemma4:e2b
#   AGENT_MODEL=ollama_chat/gemma4:e2b
# With a local model, message text never leaves your machine. Verify with:
#   uv run python verify_local.py
# Optional: point at a non-default Ollama host.
# OLLAMA_API_BASE=http://localhost:11434

# --- Media transcription model ---
# Default: cloud Gemini for everything (voice notes, video, images).
MEDIA_MODEL=gemini-2.5-flash
#
# Images can run fully local: set MEDIA_MODEL=ollama_chat/gemma4:e2b (needs
# the same Ollama setup as AGENT_MODEL). Voice notes and video still go to
# Gemini even with a local MEDIA_MODEL — Ollama's own API doesn't support
# audio/video input yet (Gemma 4 can, Ollama's API can't, as of this
# writing), so GEMINI_API_KEY is still required for those. Set both if you
# want images local and audio/video to keep working.

# Extra WebSocket origins allowed to connect (comma-separated). The backend
# already trusts https://web.whatsapp.com and chrome-extension:// origins.
# Only add entries here if you connect from somewhere else during development.
# ALLOWED_WS_ORIGINS=http://localhost:5173
